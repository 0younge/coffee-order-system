# 로컬 실행 전 이 파일을 .env로 복사하고 환경에 맞게 값을 변경합니다.
# 실제 비밀값이 들어간 .env와 .env.* 파일은 커밋하지 않습니다.

DB_NAME=coffee_order_system
DB_PORT=3307
DB_URL=jdbc:mysql://localhost:3307/coffee_order_system
DB_USERNAME=coffee
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-root

# 예: openssl rand -base64 32
JWT_SECRET_BASE64=
COLLECTION_API_BASE_URL=http://localhost:8081
